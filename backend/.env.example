PORT=5001

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/auth_db

# JWT Secret — use a long random string
JWT_SECRET=your_super_secret_jwt_key_change_this

JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# ── Email (Gmail) ──────────────────────────────
# Step 1: Use your Gmail address below
EMAIL_USER=yourname@gmail.com

# Step 2: Use a Gmail App Password (NOT your normal Gmail password)
# How to get one:
#   1. Go to myaccount.google.com
#   2. Search "App Passwords"
#   3. Select app: Mail, device: Other → type "Node"
#   4. Copy the 16-character password and paste here (no spaces)
EMAIL_PASS=your_16_char_app_password
